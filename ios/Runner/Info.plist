	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>NSContactsUsageDescription</key>
	<string>This app requires contacts access to import and export contacts.</string>
	<key>NSCameraUsageDescription</key>
	<string>TwentyMobile usa la fotocamera per scansionare biglietti da visita</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>TwentyMobile accede alla galleria per importare biglietti da visita</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>TwentyMobile usa il riconoscimento vocale per trascrivere note vocali sui tuoi contatti</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>TwentyMobile usa il microfono per registrare note vocali</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>
</dict>
</plist>
